fn target
  { dom clk: Clock, rstn: Reset @clk = high, c: uint(8) @clk = 0 }
  ( a: uint(8) @clk )
  -> uint(8) @clk
  {
    return a.reg(rstn, 0);
  }

fn caller
  { dom clk: Clock, rstn: Reset @clk = high }
  ( x: uint(8) @clk )
  -> uint(8) @clk
  {
    var captured: Reset @clk;
    let made = target { rstn => captured }(x);
    return made;
  }
