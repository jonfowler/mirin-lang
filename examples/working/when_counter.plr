// Counter using the `when` keyword to register state, without any reset.
// `when clk.posedge() { … }` lowers to `always_ff @(posedge clk)` —
// the body's tail value (`count + 1`) is the D-input, and the expression's
// value is the held register output (the previous cycle's value).
fn counter {dom clk: Clock} () -> uint(8) @clk {
    var count: uint(8) @clk;
    count = when clk.posedge() { count + 1 };
    count
}
