// Inline modules (planning/modules.md §4.1). `mod` is a name-resolution
// scope only — it flattens away before HIR, so the generated SystemVerilog is
// identical to the same `fn` written at the crate root.
mod arith {
    fn multAdd
        {dom clk: Clock, rstn: Reset @clk = high, c: uint(8) @clk = 0}
        (a: uint(8) @clk, b: uint(8) @clk)
        -> uint(8) @clk {
        let mult = a * b;
        let mult = mult.reg(rstn, 0);
        let add = mult + c;
        return add;
    }
}
