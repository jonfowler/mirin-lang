fn scale_all {dom clk: Clock} (v: Vec(3, uint(8)) @clk, k: uint(8) @clk) -> uint(8) @clk {
    var outs: Vec(3, uint(8)) @clk;
    for (i, x) in v.enumerate() {
        outs[i] = x * k;
    }
    outs[0] + outs[1] + outs[2]
}

fn popcount_ish {dom clk: Clock} (raw: bits(4) @clk) -> uint(4) @clk {
    var hits: Vec(4, uint(4)) @clk;
    for (i, b) in raw.enumerate() {
        hits[i] = if b { 1 } else { 0 };
    }
    hits[0] + hits[1] + hits[2] + hits[3]
}
