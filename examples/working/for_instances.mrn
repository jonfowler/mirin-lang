fn stage {dom clk: Clock} (x: uint(8) @clk, k: uint(8) @clk) -> uint(8) @clk {
    x * k
}

fn pipeline {dom clk: Clock} (v: Vec(3, uint(8)) @clk, k: uint(8) @clk) -> uint(8) @clk {
    var outs: Vec(3, uint(8)) @clk;
    for (i, x) in v.enumerate() {
        outs[i] = stage(x, k);
    }
    outs[2]
}
