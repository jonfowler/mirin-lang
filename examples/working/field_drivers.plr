// Driving a var struct field-by-field: check_drivers' per-leaf accounting
// accepts disjoint field paths (each leaf driven once). The failing twin —
// a whole-var drive overlapping a field drive — is
// fail-expected/double-drive-field.plr.
struct Pair = pair {
    a: uint(8),
    b: uint(8),
}

fn top(x: uint(8)) -> uint(8) {
    var p: Pair;
    p.a = x;
    p.b = x;
    p.a + p.b
}
