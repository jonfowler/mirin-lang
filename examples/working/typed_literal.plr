// verilator: -Gn=8
// Explicit literal construction (planning/numeric_literals.md L4): the
// value in the type's associated-const namespace. `uint(8)::0x40` is
// exactly uint(8) (emitted in its source base, 8'h40); a parametric
// `uint(n)::1` fit-checks at elaboration.
fn f {dom clk: Clock} (x: uint(8) @clk) -> uint(8) @clk {
    let m = x + uint(8)::0x40;
    m + uint(8)::255
}

fn g {param n: integer} (x: uint(n)) -> uint(n) {
    x + uint(n)::1
}
