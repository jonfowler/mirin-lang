struct Bus(A: Type) = bus {
  valid: bool,
  data: A,
}

cmp registerBus
  { #clk: Clock, rstn: Reset @clk = high }
  ( input: Bus(uint[8]) @clk )
  -> Bus(uint[8]) @clk
  {
    let output = input.reg{
      rstn,
      reset_val = bus {
        valid: false,
        data: 0,
      },
    }();

    return output;
  }
