fn no_dom_reg {dom clk: Clock} () -> uint(8) @clk {
    // this should fail because count is created with no domain, so should be @const
    // but then we return it and it should have @clk domain
    // count is applied to a reg which should require a proper domain.
    // NOTE: reg doesn't have the correct type to deal with this yet.
    var count: uint(8);
    count = (count + 1).reg{ reset_val = 0 }();

    count
}
