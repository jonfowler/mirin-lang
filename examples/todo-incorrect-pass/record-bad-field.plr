// MUST REJECT: `c` is not a field of `Pair`. infer's `infer_record` looks
// each written field up in the struct sig and silently skips names it
// doesn't find (no diagnostic, value type-checked against nothing) — and
// `b` is never checked as missing either.
struct Pair = pair {
    a: uint(8),
    b: uint(8),
}

fn top() -> uint(8) {
    let p = pair { a = 1, c = 2 };
    p.a
}
