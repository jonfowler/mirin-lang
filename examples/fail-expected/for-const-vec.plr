// Only range(n) iterates compile-time integers: [3,1,2]'s values are
// not 0..N-1, so they cannot be the genvar (a future const-vec story
// will lower them as elaboration constants).
fn f {dom clk: Clock} (a: uint(8) @clk) -> uint(8) @clk {
    var v: Vec(3, uint(8)) @clk;
    for i in ([3, 1, 2]) {
        v[i] = a;
    }
    v[0]
}
