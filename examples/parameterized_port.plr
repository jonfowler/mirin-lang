port DF
  { #clk: Clock }
  ( A: Type )
  = df {
    in ready: bool @clk,
    out valid: bool @clk,
    out data: A @clk,
  }

cmp connectDf
  { #clk: Clock }
  ( upstream: DF{clk}(uint[8]), out downstream: DF{clk}(uint[8]) )
  {
    downstream.valid = upstream.valid;
    downstream.data = upstream.data;
    upstream.ready = downstream.ready;
  }
