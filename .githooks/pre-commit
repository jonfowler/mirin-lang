#!/usr/bin/env bash
# Reject a commit whose staged examples/working/*.mrn are not mirin-fmt-clean.
#
# Enable in a fresh clone with:  git config core.hooksPath .githooks
# (this repo sets it; the line above is for new checkouts).

set -euo pipefail

root="$(git rev-parse --show-toplevel)"
cd "$root"

# Staged (added/copied/modified) .mrn files under examples/working.
mapfile -t files < <(
    git diff --cached --name-only --diff-filter=ACM -- examples/working \
        | grep '\.mrn$' || true
)
[ "${#files[@]}" -eq 0 ] && exit 0

# Use a prebuilt formatter if present; otherwise build it once.
bin=""
for cand in target/release/mirin-fmt target/debug/mirin-fmt; do
    [ -x "$cand" ] && bin="$cand" && break
done
if [ -z "$bin" ]; then
    echo "pre-commit: building mirin-fmt…" >&2
    cargo build -q -p mirin-fmt
    bin="target/debug/mirin-fmt"
fi

# Check the *staged* content of each file (not the working tree), so the hook
# verifies exactly what is about to be committed.
unformatted=()
for f in "${files[@]}"; do
    if ! git show ":$f" | "$bin" --check - >/dev/null 2>&1; then
        unformatted+=("$f")
    fi
done

if [ "${#unformatted[@]}" -ne 0 ]; then
    echo "pre-commit: these staged examples are not mirin-fmt-formatted:" >&2
    printf '  %s\n' "${unformatted[@]}" >&2
    echo >&2
    echo "  fix: $bin ${unformatted[*]}" >&2
    exit 1
fi
