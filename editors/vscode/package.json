{
  "name": "mirin-lsp",
  "displayName": "Mirin",
  "description": "Mirin HDL language support: syntax highlighting + the mirin-lsp language server",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "publisher": "jonfowler",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonfowler/mirin-lang.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:mirin"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "configurationDefaults": {
      "[mirin]": {
        "editor.defaultFormatter": "jonfowler.mirin-lsp",
        "editor.formatOnSave": true
      }
    },
    "languages": [
      {
        "id": "mirin",
        "aliases": [
          "Mirin",
          "mirin"
        ],
        "extensions": [
          ".mrn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mirin",
        "scopeName": "source.mirin",
        "path": "./syntaxes/mirin.tmLanguage.json"
      },
      {
        "scopeName": "markdown.mirin.codeblock",
        "path": "./syntaxes/mirin.markdown-injection.json",
        "injectTo": ["text.html.markdown"],
        "embeddedLanguages": {
          "meta.embedded.block.mirin": "mirin"
        }
      }
    ],
    "configuration": {
      "title": "Mirin",
      "properties": {
        "mirin.server.path": {
          "type": "string",
          "default": "mirin-lsp",
          "description": "Path to the mirin-lsp language server binary. Defaults to `mirin-lsp` on your PATH; set an absolute path (e.g. the repo's target/release/mirin-lsp) otherwise."
        },
        "mirin.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the JSON-RPC traffic between VS Code and mirin-lsp."
        }
      }
    }
  }
}
