{
  "name": "polar-lsp",
  "displayName": "Polar",
  "description": "Polar HDL language support: syntax highlighting + the polar-lsp language server",
  "version": "0.1.0",
  "license": "MIT OR Apache-2.0",
  "publisher": "jonfowler",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonfowler/polar.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:polar"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "contributes": {
    "configurationDefaults": {
      "[polar]": {
        "editor.defaultFormatter": "jonfowler.polar-lsp",
        "editor.formatOnSave": true
      }
    },
    "languages": [
      {
        "id": "polar",
        "aliases": [
          "Polar",
          "polar"
        ],
        "extensions": [
          ".plr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "polar",
        "scopeName": "source.polar",
        "path": "./syntaxes/polar.tmLanguage.json"
      },
      {
        "scopeName": "markdown.polar.codeblock",
        "path": "./syntaxes/polar.markdown-injection.json",
        "injectTo": ["text.html.markdown"],
        "embeddedLanguages": {
          "meta.embedded.block.polar": "polar"
        }
      }
    ],
    "configuration": {
      "title": "Polar",
      "properties": {
        "polar.server.path": {
          "type": "string",
          "default": "polar-lsp",
          "description": "Path to the polar-lsp language server binary. Defaults to `polar-lsp` on your PATH; set an absolute path (e.g. the repo's target/release/polar-lsp) otherwise."
        },
        "polar.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the JSON-RPC traffic between VS Code and polar-lsp."
        }
      }
    }
  }
}
