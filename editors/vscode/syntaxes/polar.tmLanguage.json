{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Polar",
  "scopeName": "source.polar",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#associated-functions"
    },
    {
      "include": "#method-calls"
    },
    {
      "include": "#field-access"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#domain-markers"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.polar",
          "match": "//.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.function.polar"
            },
            "2": {
              "name": "entity.name.function.polar"
            }
          }
        },
        {
          "match": "\\b(struct|port|impl|trait|mod)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.polar"
            },
            "2": {
              "name": "entity.name.type.polar"
            }
          }
        }
      ]
    },
    "associated-functions": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b(::)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.polar"
            },
            "2": {
              "name": "keyword.operator.path.polar"
            },
            "3": {
              "name": "entity.name.function.polar"
            }
          }
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:\\{|\\())",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.polar"
            },
            "2": {
              "name": "entity.name.function.polar"
            }
          }
        }
      ]
    },
    "field-access": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.polar"
            },
            "2": {
              "name": "variable.other.member.polar"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "variable.language.self.polar",
          "match": "\\bself\\b"
        },
        {
          "name": "keyword.control.polar",
          "match": "\\b(if|else|when|for|return)\\b"
        },
        {
          "name": "keyword.other.polar",
          "match": "\\b(fn|struct|port|impl|trait|mod|use|const|where|as|verilog)\\b"
        },
        {
          "name": "storage.modifier.polar",
          "match": "\\b(pub|crate|super|let|var|in|out|param|dom|init)\\b"
        },
        {
          "name": "constant.language.polar",
          "match": "\\b(high|low|true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.polar",
          "match": "\\b(uint|sint|bits|integer|bool|Clock|Reset|Event|Vec|Type|Self)\\b"
        },
        {
          "name": "entity.name.type.polar",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "domain-markers": {
      "patterns": [
        {
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.domain.polar"
            },
            "2": {
              "name": "entity.name.label.polar"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.hexadecimal.polar",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.integer.binary.polar",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.integer.decimal.polar",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.polar",
          "match": "=>|->|::|\\+|-|\\*|=|:"
        }
      ]
    }
  }
}
