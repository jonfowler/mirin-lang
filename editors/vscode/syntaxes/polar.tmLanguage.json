{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Polar",
  "scopeName": "source.polar",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#associated-functions"
    },
    {
      "include": "#method-calls"
    },
    {
      "include": "#field-access"
    },
    {
      "include": "#bindings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#domain-markers"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.polar",
          "match": "//.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(cmp|struct|port|impl)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.type.polar"
            },
            "2": {
              "name": "entity.name.type.polar"
            }
          }
        },
        {
          "match": "\\b(fn)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:\\{|\\())",
          "captures": {
            "1": {
              "name": "storage.type.function.polar"
            },
            "2": {
              "name": "entity.name.function.polar"
            }
          }
        }
      ]
    },
    "associated-functions": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b(::)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "entity.name.type.polar"
            },
            "2": {
              "name": "keyword.operator.path.polar"
            },
            "3": {
              "name": "entity.name.function.polar"
            }
          }
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:\\{|\\())",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.polar"
            },
            "2": {
              "name": "entity.name.function.polar"
            }
          }
        }
      ]
    },
    "field-access": {
      "patterns": [
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.polar"
            },
            "2": {
              "name": "variable.other.member.polar"
            }
          }
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "name": "variable.language.self.polar",
          "match": "\\bself\\b"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:,|=)\\s*(?:[^:]|$))",
          "captures": {
            "1": {
              "name": "variable.parameter.polar"
            }
          }
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*:)",
          "captures": {
            "1": {
              "name": "variable.parameter.polar"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.polar",
          "match": "\\b(let|return|rec)\\b"
        },
        {
          "name": "storage.modifier.polar",
          "match": "\\b(const|in|out)\\b"
        },
        {
          "name": "constant.language.polar",
          "match": "\\b(high|low|true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.polar",
          "match": "\\b(Clock|Reset|bool|usize|uint)\\b"
        },
        {
          "name": "entity.name.type.polar",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "domain-markers": {
      "patterns": [
        {
          "match": "(#)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.inference.polar"
            },
            "2": {
              "name": "variable.parameter.polar"
            }
          }
        },
        {
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.domain.polar"
            },
            "2": {
              "name": "entity.name.label.polar"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.decimal.polar",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.polar",
          "match": "::|->|=|\\+|\\*|:"
        }
      ]
    }
  }
}
