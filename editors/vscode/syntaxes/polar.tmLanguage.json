{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Polar",
  "scopeName": "source.polar",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#domain-markers"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.polar",
          "match": "//.*$"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(cmp|struct|port|impl|fn)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.polar"
            },
            "2": {
              "name": "entity.name.type.polar"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.polar",
          "match": "\\b(let|return|rec|const|in|out)\\b"
        },
        {
          "name": "constant.language.polar",
          "match": "\\b(high|low|true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.polar",
          "match": "\\b(Clock|Reset|bool|usize|uint)\\b"
        }
      ]
    },
    "domain-markers": {
      "patterns": [
        {
          "match": "(#)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.inference.polar"
            },
            "2": {
              "name": "variable.parameter.polar"
            }
          }
        },
        {
          "match": "(@)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.domain.polar"
            },
            "2": {
              "name": "entity.name.label.polar"
            }
          }
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.decimal.polar",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.polar",
          "match": "->|=|\\+|\\*|:"
        }
      ]
    }
  }
}
